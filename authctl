#!/usr/bin/env bash
# authctl — wrapper for manage_users.php

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANAGE="${SCRIPT_DIR}/manage_users.php"

USERS_DIR="/etc/simplewebauth"
USERS_FILE="${USERS_DIR}/auth_users.php"

# ── web user detection ────────────────────────────────────────────────────────
# Override by setting SIMPLEWEBAUTH_WEB_USER in the environment before calling authctl.

detect_web_user() {
    if [[ -n "${SIMPLEWEBAUTH_WEB_USER:-}" ]]; then
        echo "$SIMPLEWEBAUTH_WEB_USER"
        return
    fi
    for u in www-data apache nginx http; do
        if id "$u" &>/dev/null 2>&1; then
            echo "$u"
            return
        fi
    done
    echo "www-data"  # fallback
}

# ── helpers ───────────────────────────────────────────────────────────────────

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "$*"; }

require_php() {
    command -v php &>/dev/null || die "php not found in PATH"
}

require_manage() {
    [[ -f "$MANAGE" ]] || die "manage_users.php not found at: $MANAGE"
}

ensure_dir() {
    [[ -d "$USERS_DIR" ]] && return 0
    [[ $EUID -eq 0 ]] || die "${USERS_DIR} does not exist — run as root or with sudo to create it"
    local web_user
    web_user="$(detect_web_user)"
    info "Creating ${USERS_DIR}  (owner: root:${web_user}  mode: 750)"
    mkdir -p "$USERS_DIR"
    chown "root:${web_user}" "$USERS_DIR"
    chmod 750 "$USERS_DIR"
}

fix_perms() {
    # Sets auth_users.php to root:<web_user> 640 after any write.
    # Silently skips if not root (PHP already wrote the file; perms just won't be tightened).
    [[ -f "$USERS_FILE" ]] || return 0
    [[ $EUID -eq 0 ]]      || return 0
    local web_user
    web_user="$(detect_web_user)"
    chown "root:${web_user}" "$USERS_FILE"
    chmod 640 "$USERS_FILE"
}

run() {
    require_php
    require_manage
    php "$MANAGE" "$@"
}

# ── usage ─────────────────────────────────────────────────────────────────────

usage_main() {
    cat <<EOF
authctl — manage PHP auth users

Usage:
  authctl <command> [options]

Commands:
  list                    List all configured users
  add <username>          Add a new user (prompts for password)
  remove <username>       Remove a user
  passwd <username>       Change a user's password
  check                   Verify environment and show configuration

Options:
  -h, --help              Show this help message

Run 'authctl <command> --help' for command-specific help.
EOF
}

usage_add() {
    cat <<EOF
Usage: authctl add <username>

Add a new user. You will be prompted to enter a password.
Passwords must be at least 8 characters.
Creates ${USERS_DIR} with correct ownership and permissions if it does not exist (requires root).

Example:
  authctl add alice
  sudo authctl add alice
EOF
}

usage_remove() {
    cat <<EOF
Usage: authctl remove <username>

Remove a user. This action cannot be undone.

Example:
  authctl remove alice
EOF
}

usage_passwd() {
    cat <<EOF
Usage: authctl passwd <username>

Change the password for an existing user.
You will be prompted to enter the new password.

Example:
  authctl passwd alice
EOF
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_list() {
    run list
}

cmd_add() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage_add; exit 0; }
    [[ $# -lt 1 ]] && { usage_add >&2; exit 1; }
    local username="$1"
    ensure_dir
    run add "$username"
    fix_perms
}

cmd_remove() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage_remove; exit 0; }
    [[ $# -lt 1 ]] && { usage_remove >&2; exit 1; }
    local username="$1"

    read -r -p "Remove user '${username}'? This cannot be undone. [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }

    run remove "$username"
    fix_perms
}

cmd_passwd() {
    [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage_passwd; exit 0; }
    [[ $# -lt 1 ]] && { usage_passwd >&2; exit 1; }
    local username="$1"
    run passwd "$username"
    fix_perms
}

cmd_check() {
    local ok=true
    local web_user
    web_user="$(detect_web_user)"

    if command -v php &>/dev/null; then
        info "  php:              $(command -v php) ($(php -r 'echo PHP_VERSION;'))"
    else
        info "  php:              NOT FOUND"
        ok=false
    fi

    if [[ -f "$MANAGE" ]]; then
        info "  manage_users.php: $MANAGE"
    else
        info "  manage_users.php: NOT FOUND at $MANAGE"
        ok=false
    fi

    if [[ -d "$USERS_DIR" ]]; then
        info "  users dir:        $USERS_DIR  $(stat -c 'owner:%U:%G mode:%a' "$USERS_DIR")"
    else
        info "  users dir:        NOT FOUND at $USERS_DIR (run 'sudo authctl add <user>' to create)"
        ok=false
    fi

    if [[ -f "$USERS_FILE" ]]; then
        info "  users file:       $USERS_FILE  $(stat -c 'owner:%U:%G mode:%a' "$USERS_FILE")"
    else
        info "  users file:       NOT FOUND (will be created on first 'add')"
    fi

    info "  web user:         ${web_user}  (override with SIMPLEWEBAUTH_WEB_USER)"

    $ok && info $'\nAll checks passed.' || { info $'\nOne or more checks failed.'; exit 1; }
}

# ── main ──────────────────────────────────────────────────────────────────────

[[ $# -eq 0 ]] && { usage_main; exit 0; }

case "$1" in
    list)            shift; cmd_list "$@" ;;
    add)             shift; cmd_add "$@" ;;
    remove|rm|del)   shift; cmd_remove "$@" ;;
    passwd|password) shift; cmd_passwd "$@" ;;
    check)           shift; cmd_check "$@" ;;
    -h|--help|help)  usage_main; exit 0 ;;
    *)               echo "Unknown command: $1"; echo; usage_main >&2; exit 1 ;;
esac
