# Block direct web access to sensitive PHP files
<FilesMatch "^(auth_users|manage_users)\.php$">
    Require all denied
</FilesMatch>

# Block documentation, scripts, and other non-web files
<FilesMatch "^(README\.md|LICENSE|authctl)$">
    Require all denied
</FilesMatch>

# Block dot-directories (returns 404 rather than 403 to avoid confirming existence)
RedirectMatch 404 ^/\.git(/|$)
